        <!-- Loading text -->
        <div class="loading-text">
            <h1 class="main-message">Good code loads fast.</h1>
            <h2 class="fetching-message">Fetching high-res bestagons...</h2>
        </div>
    </div>

    <div id="ui">
        <div class="glass-panel" id="main-panel">
            <div class="panel-header">
                <div class="header-content">
                    <h1>POWFINDER 3D</h1>
                    <div class="subtitle">Binary Hex Piston Engine</div>
                </div>
                <button id="minimize-btn" class="minimize-btn" title="Minimize Panel">−</button>
            </div>

            <div class="panel-body">
                <div class="stats">
                    <div class="hud-item">
                        <span>LOCATION</span>
                        <span class="value" id="loc-val">SULZENAU, TIROL</span>
                    </div>
                    <!-- === DEBUG: Render Analysis === -->
                    <div class="hud-item">
                        <span>FPS / ZOOM</span>
                        <span class="value" id="fps-counter">--</span>
                    </div>
                    <div class="hud-item">
                        <span>HEXAGONS</span>
                        <span class="value" id="hex-count">-- VISIBLE</span>
                    </div>
                    <div class="hud-item">
                        <span>TRIANGLES</span>
                        <span class="value" id="tri-count">-- / -- (--)</span>
                    </div>
                    <div class="hud-item">
                        <span>DRAW CALLS</span>
                        <span class="value" id="draw-stats">-- | G:-- | T:--</span>
                    </div>
                    <div class="hud-item">
                        <span>SECTOR</span>
                        <span class="value" id="sector-val">--</span>
                    </div>
                    <div class="hud-item">
                        <span>HEX</span>
                        <span class="value" id="hex-val">--</span>
                    </div>
                    <div class="hud-item">
                        <span>WORLD XY</span>
                        <span class="value" id="world-val">--</span>
                    </div>
                    <div class="hud-item">
                        <span>TILE HEIGHT</span>
                        <span class="value" id="tile-height">--m</span>
                    </div>
                    <div class="hud-item">
                        <span>CAMERA HEIGHT</span>
                        <span class="value" id="camera-height">--m</span>
                    </div>

                    <div class="hud-item"
                        style="margin-top: 10px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px;">
                        <span>LOD BENCHMARK (MS)</span>
                    </div>

                    <div class="hud-item"
                        style="justify-content: space-between; font-family: 'Courier New', monospace; font-size: 10px;"
                        title="O(N) Brute Force: Iterates through every single sector in the world for every frame. Slowest method, scales poorly with map size.">
                        <span style="color: #aaa;">LINEAR SCAN</span>
                        <span class="value" id="bench-loop" style="color: #ff6b9d;">--</span>
                    </div>
                    <div class="hud-item"
                        style="justify-content: space-between; font-family: 'Courier New', monospace; font-size: 10px;"
                        title="O(log N) Spatial Tree: Recursively subdivides space into quadrants. Efficiently discards large chunks of the world outside the view range.">
                        <span style="color: #aaa;">QUAD TREE</span>
                        <span class="value" id="bench-tree" style="color: #74b9ff;">--</span>
                    </div>
                    <div class="hud-item"
                        style="justify-content: space-between; font-family: 'Courier New', monospace; font-size: 10px;"
                        title="O(1) Spatial Hash: Maps coordinates directly to grid buckets. Near-instant constant time lookup, but uses more memory for the hash table.">
                        <span style="color: #aaa;">GRID HASH</span>
                        <span class="value" id="bench-hash" style="color: #2ecc71;">--</span>
                    </div>

                    <!-- === END DEBUG === -->
                    <div class="hud-item">
                        <span>PRECISION</span>
                        <span class="value">FLOAT16 (CM)</span>
                    </div>
                    <div class="hud-item"
                        style="margin-top: 15px; border-bottom: 1px solid #333; padding-bottom: 5px; color: #fff; font-weight: bold;">
                        GEOMETRY (VERTEX)
                    </div>
                    <!-- Geometry Controls -->
                    <div class="hud-item" style="flex-direction: column; align-items: stretch; margin-top: 10px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span>UNIT HEX (CLOSE)</span>
                            <span class="value" id="geo-lod0-val">200m</span>
                        </div>
                        <input type="range" id="geo-lod0-slider" min="0" max="1000" step="10" value="200"
                            style="width: 100%; pointer-events: auto;">
                    </div>
                    <div class="hud-item" style="flex-direction: column; align-items: stretch; margin-top: 5px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span>SMALL HEX</span>
                            <span class="value" id="geo-lod1-val">500m</span>
                        </div>
                        <input type="range" id="geo-lod1-slider" min="0" max="2000" step="50" value="500"
                            style="width: 100%; pointer-events: auto;">
                    </div>
                    <div class="hud-item" style="flex-direction: column; align-items: stretch; margin-top: 5px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span>MEDIUM HEX</span>
                            <span class="value" id="geo-lod2-val">1000m</span>
                        </div>
                        <input type="range" id="geo-lod2-slider" min="0" max="5000" step="100" value="1000"
                            style="width: 100%; pointer-events: auto;">
                    </div>
                    <div class="hud-item" style="flex-direction: column; align-items: stretch; margin-top: 5px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span>VIEW DIST (MAX)</span>
                            <span class="value" id="geo-lod3-val">2000m</span>
                        </div>
                        <input type="range" id="geo-lod3-slider" min="0" max="10000" step="100" value="2000"
                            style="width: 100%; pointer-events: auto;">
                    </div>

                    <div class="hud-item"
                        style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px; border-top: 1px solid #333; padding-top: 10px;">
                        <span>SAFETY OVERLAY</span>
                        <input type="checkbox" id="safety-toggle" checked style="pointer-events: auto;">
                    </div>

                    <div class="hud-item"
                        style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                        <span>PAUSE LOD UPDATES</span>
                        <input type="checkbox" id="lod-pause-toggle" style="pointer-events: auto;">
                    </div>

                    <div class="hud-item"
                        style="margin-top: 15px; border-bottom: 1px solid #333; padding-bottom: 5px; color: #fff; font-weight: bold;">
                        TEXTURE (VRAM)
                    </div>
                    <!-- Texture Controls -->
                    <div class="hud-item" style="flex-direction: column; align-items: stretch; margin-top: 10px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom:5px;">
                            <span>FULL RES (0.2m)</span>
                            <span class="value" id="tex-lod0-val">500m</span>
                        </div>
                        <input type="range" id="tex-lod0-slider" min="0" max="2000" step="50" value="500"
                            style="width: 100%; pointer-events: auto;">
                    </div>
                    <div class="hud-item" style="flex-direction: column; align-items: stretch; margin-top: 5px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom:5px;">
                            <span>HIGH RES (~0.8m)</span>
                            <span class="value" id="tex-lod1-val">∞</span>
                        </div>
                        <input type="range" id="tex-lod1-slider" min="0" max="5000" step="100" value="1500"
                            style="width: 100%; pointer-events: auto;">
                    </div>

                    <div class="hud-item"
                        style="margin-top: 15px; border-bottom: 1px solid #333; padding-bottom: 5px; color: #fff; font-weight: bold;">
                        RENDER DISTANCE
                    </div>
                    <div class="hud-item" style="flex-direction: column; align-items: stretch; margin-top: 10px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span>MAX RANGE</span>
                            <span class="value" id="render-distance-val">20km</span>
                        </div>
                        <input type="range" id="render-distance-slider" min="1" max="50" step="1" value="20"
                            style="width: 100%; pointer-events: auto;">
                    </div>
                </div>

                <div class="hud-item frametime-item">
                    <canvas id="frametime-graph" width="640" height="80"></canvas>
                </div>
            </div>

            <div class="info-panel">
                <div class="tech-header">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                    </svg>
                    Why Bestagons?
                </div>
                <div class="tech-description">
                    Utilizing a single GPU Draw Call for the entire terrain.
                    <span class="tech-spec">
                        - 1DrawCall / 15k Hexes<br>
                        - Zero DrawCall Overhead<br>
                        - 14-Byte Manifold Stream<br>
                        - Dynamic Piston Animation
                    </span>
                </div>
            </div>

            <div class="console-panel">
                <div class="console-header">
                    <span>STATUS LOG</span>
                    <button id="copy-log-btn" class="console-btn">COPY</button>
                </div>
                <div id="console-output" class="console-box">
                    <div class="log-line">Waiting for system...</div>
                </div>
            </div>
        </div>
    </div>
    </div>

    <div class="legend glass-panel">
        <div class="legend-item">
            <div class="swatch" style="background:#555;"></div>
            < 10° PLAIN</div>
                <div class="legend-item">
                    <div class="swatch" style="background:#2ecc71;"></div> 10-25° EASY
                </div>
                <div class="legend-item">
                    <div class="swatch" style="background:#3498db;"></div> 25-30° MODERATE
                </div>
                <div class="legend-item">
                    <div class="swatch" style="background:#e74c3c;"></div> > 30° DANGER
                </div>
        </div>

        <div id="css-map-layer">
            <div id="css-world"></div>
        </div>
        <div id="canvas-container"></div>

        <script type="module" src="main.js"></script>
